generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTION
}

enum OrderStatus {
  IN_PROGRESS
  READY
  PICKED_UP
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         Role
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ordersCreated Order[]  @relation("OrderCreatedBy")
  expenses      Expense[]
}

/// Reference list for admin expense category dropdowns; name is snapshotted on each expense.
model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  expenses  Expense[]

  @@unique([name])
}

model Expense {
  id                String          @id @default(cuid())
  expenseCategoryId String
  expenseCategory   ExpenseCategory @relation(fields: [expenseCategoryId], references: [id])
  /// Snapshot of category name at time of save
  categoryName      String
  amount            Decimal         @db.Decimal(12, 2)
  expenseDate       DateTime        @db.Date
  description       String?
  createdById       String
  createdBy         User            @relation(fields: [createdById], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([expenseDate])
  @@index([createdById])
  @@index([expenseCategoryId])
}

/// Laundry service category (Dry Clean, Wash and Fold, Shoes, Other). Admin-managed.
model ServiceCategory {
  id                   String         @id @default(cuid())
  name                 String
  sortOrder            Int            @default(0)
  isActive             Boolean        @default(true)
  /// When true (e.g. "Other"), reception enters custom item name + unit price; no catalog item row needed.
  allowsCustomPricing  Boolean        @default(false)
  items                ServiceItem[]
  orderItems           OrderItem[]

  @@unique([name])
}

/// Priced item under a service category. Admin-managed default price; reception cannot override except via "Other".
model ServiceItem {
  id                String          @id @default(cuid())
  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)
  name              String
  defaultPrice      Decimal         @db.Decimal(12, 2)
  sortOrder         Int             @default(0)
  isActive          Boolean         @default(true)
  orderItems        OrderItem[]

  @@index([serviceCategoryId])
  @@unique([serviceCategoryId, name])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  createdById String
  createdBy   User        @relation("OrderCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  notes       String?
  customerName  String
  customerPhone String
  totalAmount Decimal     @db.Decimal(12, 2)
  orderStatus OrderStatus @default(IN_PROGRESS)
  items       OrderItem[]

  @@index([createdById])
  @@index([createdAt])
}

model OrderItem {
  id                String           @id @default(cuid())
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceCategoryId String
  serviceCategory   ServiceCategory  @relation(fields: [serviceCategoryId], references: [id])
  /// Snapshot of category name at time of order
  categoryName      String
  /// Set when line uses a catalog item; null for custom "Other" lines
  serviceItemId     String?
  serviceItem       ServiceItem?     @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)
  /// Snapshot: ServiceItem.name or custom name for Other
  itemName          String
  quantity          Int
  unitPrice         Decimal          @db.Decimal(12, 2)
  lineTotal         Decimal          @db.Decimal(12, 2)
  sortOrder         Int              @default(0)

  @@index([orderId])
  @@index([serviceCategoryId])
  @@index([serviceItemId])
}
